{
  "name": "sponsor-banner",
  "version": "1.0.0",
  "description": "Generate customizable sponsor banner images for README files, profiles, and project pages.",
  "type": "module",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc --noEmit && tsup src/server.ts --format esm --target node22 --out-dir dist --clean",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@resvg/resvg-js": "^2.6.2",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "satori": "^0.26.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
